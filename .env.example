# ================================================================
# Clipla — Frontend Environment Variables
# Bu dosyayı kopyalayın: cp .env.example .env
# EXPO_PUBLIC_ prefix'li değişkenler bundle'a dahil edilir.
# ================================================================

# ── Backend URL ───────────────────────────────────────────────────
# Geliştirme (yerel ağ):
#   EXPO_PUBLIC_BACKEND_URL=http://192.168.1.6:8000
# Production (deploy sonrası gerçek domain):
#   EXPO_PUBLIC_BACKEND_URL=https://api.clipla.com
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.6:8000

# ── API Key ───────────────────────────────────────────────────────
# Backend'deki API_SECRET_KEY ile eşleşmeli.
# EAS build'lerde eas.json env bölümüne de ekleyin.
EXPO_PUBLIC_API_KEY=clipla-dev-key-degistir

# ── Supabase ──────────────────────────────────────────────────────
# Supabase dashboard → Settings → API → Project URL & anon key
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
